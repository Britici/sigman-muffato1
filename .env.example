# SIGMAN v2.0 — variáveis de ambiente
# Copie para .env e preencha os valores

# Banco de dados
DB_NAME=sigman
DB_USER=sigman
DB_PASS=TROQUE_ESTA_SENHA

# pgAdmin
PGADMIN_EMAIL=admin@sigman.local
PGADMIN_PASS=TROQUE_ESTA_SENHA

# Node
NODE_ENV=development
PORT=3000

# Google OAuth 2.0
# Obter em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET

# Sessão (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=GERE_UMA_STRING_ALEATORIA_32_BYTES

# URL do frontend (dev)
FRONTEND_URL=http://localhost:5173
